# Ruler Configuration
# Copy this file to .env and fill in your values

# Penpot Server
PENPOT_PUBLIC_URL=http://localhost:9001

# Authentication (use either token OR email/password)
PENPOT_ACCESS_TOKEN=
PENPOT_EMAIL=
PENPOT_PASSWORD=

# Database (match your Penpot setup)
PENPOT_DB_PASS=penpot

# MCP Server
MCP_PORT=8787

# SMTP Configuration (for mailcatcher - local email catch)
# Mailcatcher provides a web UI at http://localhost:1080
PENPOT_SMTP_HOST=mailcatcher
PENPOT_SMTP_PORT=1025
PENPOT_SMTP_DEFAULT_FROM=noreply@penpot.local

# Penpot Flags (for self-hosted)
# enable-access-tokens: Allow API access tokens
# enable-login-with-password: Enable email/password login
# enable-registration: Allow new user registration
# enable-smtp: Enable SMTP (required for mailcatcher)
# disable-email-verification: Skip email verification (for self-hosted)
PENPOT_FLAGS=enable-access-tokens enable-login-with-password enable-registration enable-smtp disable-email-verification
