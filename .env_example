# Ruler Configuration
# Copy this file to .env and fill in your values

# Penpot Server
PENPOT_PUBLIC_URL=http://localhost:9001

# Authentication (use either token OR email/password)
PENPOT_ACCESS_TOKEN=
PENPOT_EMAIL=
PENPOT_PASSWORD=

# Database (match your Penpot setup)
PENPOT_DB_PASS=penpot

# MCP Server
MCP_PORT=8787
